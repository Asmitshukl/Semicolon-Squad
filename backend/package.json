{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && node --watch dist/server.js",
    "start": "node dist/server.js",
    "prisma:generate": "npx prisma generate --schema ../prisma/schema.prisma",
    "prisma:push": "npx prisma db push --schema ../prisma/schema.prisma --url \"$DATABASE_URL\""
  },
  "dependencies": {
    "@prisma/client": "^7.7.0",
    "busboy": "^1.6.0",
    "dotenv": "^17.4.1"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "prisma": "^7.7.0",
    "typescript": "^6.0.2"
  }
}
